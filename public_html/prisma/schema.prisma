  users_user_bookings_bookings_professional_idTousers_user users_user                   @relation("bookings_bookings_professional_idTousers_user", fields: [professional_id], references: [id], onUpdate: Restrict, map: "bookings_bookings_professional_id_395279ea_fk_users_user_id")
