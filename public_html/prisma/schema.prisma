  @@index([client_id], map: "bookings_bookings_client_id_12f8f110_fk_users_user_id")
  @@index([professional_id], map: "bookings_bookings_professional_id_395279ea_fk_users_user_id")
  @@index([team_id], map: "bookings_bookings_team_id_cf1f7b0b_fk_marketplace_teams_id")
