  priority                                               String                            @db.VarChar(20)
  resolution                                             String?                           @db.VarChar(20)
  resolution_notes                                       String                            @db.LongText
  resolved_at                                            DateTime?                         @db.DateTime(6)
  created_at                                             DateTime                          @db.DateTime(6)
  updated_at                                             DateTime                          @db.DateTime(6)
  initiator_id                                           BigInt
  project_id                                             BigInt
  resolved_by_id                                         BigInt?
  respondent_id                                          BigInt
  users_user_disputes_dispute_initiator_idTousers_user   users_user                        @relation("disputes_dispute_initiator_idTousers_user", fields: [initiator_id], references: [id], onUpdate: Restrict, map: "disputes_dispute_initiator_id_9b9c58fc_fk_users_user_id")
  projects_projects                                      projects_projects                 @relation(fields: [project_id], references: [id], onUpdate: Restrict, map: "disputes_dispute_project_id_7c9b768c_fk_projects_projects_id")
  users_user_disputes_dispute_resolved_by_idTousers_user users_user?                       @relation("disputes_dispute_resolved_by_idTousers_user", fields: [resolved_by_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "disputes_dispute_resolved_by_id_100fd82f_fk_users_user_id")
  users_user_disputes_dispute_respondent_idTousers_user  users_user                        @relation("disputes_dispute_respondent_idTousers_user", fields: [respondent_id], references: [id], onUpdate: Restrict, map: "disputes_dispute_respondent_id_08f53200_fk_users_user_id")
  disputes_disputeevidence                               disputes_disputeevidence[]
  disputes_disputemessage                                disputes_disputemessage[]
  disputes_justicenodeaisettlement                       disputes_justicenodeaisettlement?

  @@index([initiator_id], map: "disputes_dispute_initiator_id_9b9c58fc_fk_users_user_id")
  @@index([project_id], map: "disputes_dispute_project_id_7c9b768c_fk_projects_projects_id")
  @@index([resolved_by_id], map: "disputes_dispute_resolved_by_id_100fd82f_fk_users_user_id")
  @@index([respondent_id], map: "disputes_dispute_respondent_id_08f53200_fk_users_user_id")
}

