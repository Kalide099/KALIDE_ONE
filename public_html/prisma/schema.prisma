generator client {
  provider = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model artisans_badge {
  id                               BigInt                             @id @default(autoincrement())
  name                             String                             @db.LongText
  icon_url                         String?                            @db.VarChar(200)
  description                      String                             @db.LongText
  marketplace_professionals_badges marketplace_professionals_badges[]
}

model artisans_skillcategory {
  id                         BigInt                       @id @default(autoincrement())
  name                       String                       @db.LongText
